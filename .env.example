# Supabase — get from https://app.supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Google Gemini — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Cloudflare Turnstile site key — create at https://www.cloudflare.com/products/turnstile/
# (Turnstile SECRET key is pasted into Supabase Dashboard -> Auth -> Settings ->
#  Bot and Abuse Protection -> Turnstile -> Secret key. It is NOT used by this app.)
# Use 1x00000000000000000000AA in dev for an always-passing challenge.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
