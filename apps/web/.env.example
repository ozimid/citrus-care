# apps/web is a static marketing landing (D-16) — it needs no secrets itself.
# In local dev, apps/api falls back to reading apps/web/.env.local, so the
# Supabase + Gemini values for the API service are conventionally kept there:
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Google Gemini — get from https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
