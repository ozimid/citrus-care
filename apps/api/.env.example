# Citrus Care API — environment variables.
# In local dev you can leave apps/api/.env.local absent; the server falls back
# to reading apps/web/.env.local (same Supabase/Gemini secrets).

# Supabase (NEXT_PUBLIC_* names match apps/web; SUPABASE_URL / SUPABASE_ANON_KEY
# are accepted as fallbacks)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Gemini
GEMINI_API_KEY=

# HTTP port (default 3003)
API_PORT=3003
