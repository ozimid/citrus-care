# Citrus Care API — environment variables.
# In local dev you can leave apps/api/.env.local absent; the server falls back
# to reading apps/web/.env.local (same Supabase/Gemini secrets).

# Supabase (NEXT_PUBLIC_* names match apps/web; SUPABASE_URL / SUPABASE_ANON_KEY
# are accepted as fallbacks)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — used by the Supabase storage backend + /cleanup-orphans
# (never by user-facing auth; RLS-scoped clients handle those)
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini
GEMINI_API_KEY=

# Shared secret gating POST /cleanup-orphans (Authorization: Bearer <secret>)
CLEANUP_SECRET=

# HTTP port (default 3003)
API_PORT=3003

# --- Photo storage backend selection --------------------------------------
# Leave both UNSET to use Supabase Storage (default, today's behavior). Set
# BOTH to flip all photo I/O to Google Cloud Storage — no code change needed.
#
# GCS_PHOTOS_BUCKET: name of a bucket-scoped bucket dedicated to photos. The
#   service account below should be granted access to THIS bucket only
#   (roles/storage.objectAdmin on the bucket), not project-wide.
# GCS_SERVICE_ACCOUNT_KEY: the full service-account key JSON, on one line.
#GCS_PHOTOS_BUCKET=
#GCS_SERVICE_ACCOUNT_KEY=
