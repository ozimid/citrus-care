{
  "expo": {
    "name": "Citrus Care",
    "slug": "citrus-care",
    "version": "0.1.3",
    "scheme": "citruscare",
    "platforms": [
      "ios",
      "android"
    ],
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#059669"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.citruscare.app"
    },
    "android": {
      "package": "com.citruscare.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#059669"
      },
      "versionCode": 4
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Citrus Care uses the camera to photograph your plants for health checks."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Citrus Care uses your photo library so you can import plant photos for health checks."
        }
      ],
      "expo-notifications",
      "expo-asset",
      "expo-sharing"
    ],
    "experiments": {
      "onDemandFilesystem": false
    },
    "extra": {
      "eas": {
        "projectId": "db82c83f-6bce-4302-890e-54d22876a148"
      }
    },
    "owner": "ozimid",
    "icon": "./assets/icon.png"
  }
}